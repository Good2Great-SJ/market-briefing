# market-briefing/.env 로 복사한 뒤 값을 채워주세요. (.env는 git에 커밋하지 마세요)

# Claude API (총평 생성용) — 없으면 stock-consensus-notifier/.env 값을 자동으로 재사용합니다.
ANTHROPIC_API_KEY=

# 이메일 발송 (PDF 첨부) — Gmail 기준 "앱 비밀번호" 필요
# 생성 방법: https://myaccount.google.com/apppasswords (2단계 인증 활성화 후)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=
EMAIL_APP_PASSWORD=
EMAIL_RECEIVER=
